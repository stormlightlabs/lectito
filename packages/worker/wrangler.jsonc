{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "lectito-api-proxy",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-28",
  "routes": [{ "pattern": "lectito.stormlightlabs.org/api/*", "zone_name": "stormlightlabs.org" }],
  "vars": {
    "API_ORIGIN": "https://lectito-api.stormlightlabs.org",
    "UPSTREAM_TIMEOUT_MS": "25000",
  },
  "observability": { "enabled": true, "head_sampling_rate": 1 },
}
