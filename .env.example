# Required
DATABASE_URL=postgres://postgres:postgres@localhost:5432/lectito

# Server
LISTEN_ADDR=0.0.0.0:3000
WEB_DIR=web/build
RUST_LOG=info

# Extraction and cache behavior
CACHE_TTL_SECS=86400
FETCH_TIMEOUT_SECS=30
REQUEST_TIMEOUT_SECS=60
CLEANUP_INTERVAL_SECS=900

# Rate limiting
RATE_LIMIT_PER_MIN=60
RATE_LIMIT_PER_HOUR=600
RATE_LIMIT_PER_DAY=5000
TRUST_PROXY_HEADERS=false

# Database pool
DB_MAX_CONNECTIONS=16
DB_CONNECT_TIMEOUT_SECS=10
DB_WAIT_TIMEOUT_SECS=5
DB_CREATE_TIMEOUT_SECS=10
DB_RECYCLE_TIMEOUT_SECS=5
DB_IDLE_TIMEOUT_SECS=600

# Spam controls
BLOCKED_DOMAINS=site_configs/global.txt
ADMIN_TOKEN=change-me
AUTO_BAN_THRESHOLD=5
AUTO_BAN_WINDOW_SECS=600
AUTO_BAN_DURATION_SECS=3600
