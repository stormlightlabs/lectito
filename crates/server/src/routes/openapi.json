{
  "openapi": "3.1.0",
  "info": {
    "title": "Lectito API",
    "version": "__LECTITO_VERSION__",
    "description": "Public extraction and library API for the Lectito reader service."
  },
  "servers": [{ "url": "/", "description": "Same-origin Lectito server" }],
  "tags": [
    { "name": "Extraction", "description": "Fetch and extract readable content from web pages." },
    { "name": "Library", "description": "Browse cached articles and retrieve saved extracts." },
    { "name": "Operations", "description": "Health and rate-limit inspection endpoints." }
  ],
  "paths": {
    "/api/v1/health": {
      "get": {
        "tags": ["Operations"],
        "summary": "Health check",
        "operationId": "getHealth",
        "responses": {
          "200": {
            "description": "Server and database are reachable.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/HealthResponse" } } }
          },
          "503": {
            "description": "Server is up, but the database is unavailable.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/HealthResponse" } } }
          }
        }
      }
    },
    "/api/v1/limits": {
      "get": {
        "tags": ["Operations"],
        "summary": "Current caller rate limits",
        "operationId": "getLimits",
        "responses": {
          "200": {
            "description": "Current request window status for the calling IP.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/LimitsResponse" } } }
          }
        }
      }
    },
    "/api/v1/extract": {
      "get": {
        "tags": ["Extraction"],
        "summary": "Extract readable content with query parameters",
        "operationId": "extractArticleGet",
        "parameters": [
          { "$ref": "#/components/parameters/Url" },
          { "$ref": "#/components/parameters/Format" },
          { "$ref": "#/components/parameters/IncludeFrontmatter" },
          { "$ref": "#/components/parameters/IncludeReferences" },
          { "$ref": "#/components/parameters/StripImages" },
          { "$ref": "#/components/parameters/ContentSelector" }
        ],
        "responses": {
          "200": {
            "description": "Article extracted successfully.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ExtractResponse" } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "422": { "$ref": "#/components/responses/UnprocessableEntity" },
          "429": { "$ref": "#/components/responses/TooManyRequests" },
          "502": { "$ref": "#/components/responses/BadGateway" },
          "504": { "$ref": "#/components/responses/GatewayTimeout" }
        }
      },
      "post": {
        "tags": ["Extraction"],
        "summary": "Extract readable content from a URL",
        "operationId": "extractArticlePost",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ExtractRequest" } } }
        },
        "responses": {
          "200": {
            "description": "Article extracted successfully.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ExtractResponse" } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "422": { "$ref": "#/components/responses/UnprocessableEntity" },
          "429": { "$ref": "#/components/responses/TooManyRequests" },
          "502": { "$ref": "#/components/responses/BadGateway" },
          "504": { "$ref": "#/components/responses/GatewayTimeout" }
        }
      }
    },
    "/api/v1/library": {
      "get": {
        "tags": ["Library"],
        "summary": "Browse cached articles",
        "operationId": "listLibraryArticles",
        "parameters": [
          { "$ref": "#/components/parameters/Page" },
          { "$ref": "#/components/parameters/PerPage" },
          { "$ref": "#/components/parameters/LibrarySort" },
          { "$ref": "#/components/parameters/SearchQuery" },
          { "$ref": "#/components/parameters/Domain" },
          { "$ref": "#/components/parameters/DateFrom" },
          { "$ref": "#/components/parameters/DateTo" }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of cached article summaries and aggregate stats.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/LibraryResponse" } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/api/v1/library/{id}": {
      "get": {
        "tags": ["Library"],
        "summary": "Fetch a cached article by id",
        "operationId": "getLibraryArticle",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "UUID of the cached article.",
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Full cached article payload.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ExtractResponse" } } }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "Url": {
        "name": "url",
        "in": "query",
        "required": true,
        "description": "Absolute http(s) URL to extract.",
        "schema": { "type": "string", "format": "uri" }
      },
      "Format": {
        "name": "format",
        "in": "query",
        "required": false,
        "description": "Requested output format.",
        "schema": { "$ref": "#/components/schemas/ExtractFormat" }
      },
      "IncludeFrontmatter": {
        "name": "include_frontmatter",
        "in": "query",
        "required": false,
        "schema": { "type": "boolean", "default": false }
      },
      "IncludeReferences": {
        "name": "include_references",
        "in": "query",
        "required": false,
        "schema": { "type": "boolean", "default": false }
      },
      "StripImages": {
        "name": "strip_images",
        "in": "query",
        "required": false,
        "schema": { "type": "boolean", "default": false }
      },
      "ContentSelector": {
        "name": "content_selector",
        "in": "query",
        "required": false,
        "description": "Optional CSS selector override used instead of automatic readability detection.",
        "schema": { "type": "string" }
      },
      "Page": {
        "name": "page",
        "in": "query",
        "required": false,
        "schema": { "type": "integer", "minimum": 1, "default": 1 }
      },
      "PerPage": {
        "name": "per_page",
        "in": "query",
        "required": false,
        "schema": { "type": "integer", "minimum": 1, "maximum": 100, "default": 20 }
      },
      "LibrarySort": {
        "name": "sort",
        "in": "query",
        "required": false,
        "schema": { "$ref": "#/components/schemas/LibrarySort" }
      },
      "SearchQuery": {
        "name": "q",
        "in": "query",
        "required": false,
        "description": "Substring match against title, domain, or full URL.",
        "schema": { "type": "string" }
      },
      "Domain": {
        "name": "domain",
        "in": "query",
        "required": false,
        "description": "Exact domain filter, for example example.com.",
        "schema": { "type": "string" }
      },
      "DateFrom": {
        "name": "date_from",
        "in": "query",
        "required": false,
        "description": "Only include items fetched on or after this date.",
        "schema": { "type": "string", "format": "date" }
      },
      "DateTo": {
        "name": "date_to",
        "in": "query",
        "required": false,
        "description": "Only include items fetched on or before this date.",
        "schema": { "type": "string", "format": "date" }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "The request body or query parameters were invalid.",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      },
      "Forbidden": {
        "description": "The requested URL or caller was blocked by spam protections.",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      },
      "NotFound": {
        "description": "The requested cached article does not exist.",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      },
      "UnprocessableEntity": {
        "description": "The page was fetched, but no readable content could be extracted.",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      },
      "TooManyRequests": {
        "description": "The caller exceeded the current rate limit window.",
        "headers": {
          "Retry-After": { "description": "Seconds until another request is allowed.", "schema": { "type": "integer" } }
        },
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      },
      "BadGateway": {
        "description": "Fetching the upstream page failed.",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      },
      "GatewayTimeout": {
        "description": "Fetching the upstream page timed out.",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      }
    },
    "schemas": {
      "ExtractFormat": { "type": "string", "enum": ["html", "markdown", "text", "json"], "default": "markdown" },
      "LibrarySort": { "type": "string", "enum": ["recent", "popular", "alpha"], "default": "recent" },
      "CachedMetadata": {
        "type": "object",
        "properties": {
          "title": { "type": ["string", "null"] },
          "author": { "type": ["string", "null"] },
          "date": { "type": ["string", "null"] },
          "excerpt": { "type": ["string", "null"] },
          "site_name": { "type": ["string", "null"] },
          "language": { "type": ["string", "null"] },
          "word_count": { "type": ["integer", "null"], "minimum": 0 },
          "reading_time_minutes": { "type": ["number", "null"], "minimum": 0 },
          "image": { "type": ["string", "null"], "format": "uri" },
          "favicon": { "type": ["string", "null"], "format": "uri" }
        }
      },
      "ExtractRequest": {
        "type": "object",
        "required": ["url"],
        "properties": {
          "url": { "type": "string", "format": "uri" },
          "format": { "$ref": "#/components/schemas/ExtractFormat" },
          "include_frontmatter": { "type": "boolean", "default": false },
          "include_references": { "type": "boolean", "default": false },
          "strip_images": { "type": "boolean", "default": false },
          "content_selector": { "type": ["string", "null"] }
        },
        "example": {
          "url": "https://example.com/article",
          "format": "markdown",
          "include_frontmatter": true,
          "include_references": false,
          "strip_images": false,
          "content_selector": null
        }
      },
      "ExtractResponse": {
        "type": "object",
        "required": ["url", "format", "content", "metadata", "cached", "extracted_at"],
        "properties": {
          "id": { "type": ["string", "null"], "format": "uuid" },
          "url": { "type": "string", "format": "uri" },
          "format": { "$ref": "#/components/schemas/ExtractFormat" },
          "content": { "type": "string" },
          "metadata": { "$ref": "#/components/schemas/CachedMetadata" },
          "cached": { "type": "boolean" },
          "extracted_at": { "type": "string", "format": "date-time" }
        }
      },
      "LibraryItem": {
        "type": "object",
        "required": ["id", "url", "domain", "format", "hit_count", "fetched_at"],
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "url": { "type": "string", "format": "uri" },
          "domain": { "type": "string" },
          "format": { "$ref": "#/components/schemas/ExtractFormat" },
          "title": { "type": ["string", "null"] },
          "author": { "type": ["string", "null"] },
          "site_name": { "type": ["string", "null"] },
          "favicon": { "type": ["string", "null"], "format": "uri" },
          "excerpt": { "type": ["string", "null"] },
          "date": { "type": ["string", "null"] },
          "word_count": { "type": ["integer", "null"], "minimum": 0 },
          "reading_time_minutes": { "type": ["number", "null"], "minimum": 0 },
          "hit_count": { "type": "integer", "minimum": 0 },
          "fetched_at": { "type": "string", "format": "date-time" }
        }
      },
      "TopDomain": {
        "type": "object",
        "required": ["domain", "count"],
        "properties": { "domain": { "type": "string" }, "count": { "type": "integer", "minimum": 0 } }
      },
      "LibraryStats": {
        "type": "object",
        "required": ["total_articles", "total_reads", "unique_domains", "total_reading_time_minutes", "top_domains"],
        "properties": {
          "total_articles": { "type": "integer", "minimum": 0 },
          "total_reads": { "type": "integer", "minimum": 0 },
          "unique_domains": { "type": "integer", "minimum": 0 },
          "total_reading_time_minutes": { "type": "number", "minimum": 0 },
          "top_domains": { "type": "array", "items": { "$ref": "#/components/schemas/TopDomain" } }
        }
      },
      "LibraryResponse": {
        "type": "object",
        "required": ["items", "total", "page", "per_page", "stats"],
        "properties": {
          "items": { "type": "array", "items": { "$ref": "#/components/schemas/LibraryItem" } },
          "total": { "type": "integer", "minimum": 0 },
          "page": { "type": "integer", "minimum": 1 },
          "per_page": { "type": "integer", "minimum": 1, "maximum": 100 },
          "stats": { "$ref": "#/components/schemas/LibraryStats" }
        }
      },
      "HealthResponse": {
        "type": "object",
        "required": ["status", "version", "database"],
        "properties": {
          "status": { "type": "string" },
          "version": { "type": "string" },
          "database": { "type": "string" }
        }
      },
      "LimitsResponse": {
        "type": "object",
        "required": ["requests_remaining", "requests_limit", "window_seconds", "reset_at"],
        "properties": {
          "requests_remaining": { "type": "integer", "minimum": 0 },
          "requests_limit": { "type": "integer", "minimum": 0 },
          "window_seconds": { "type": "integer", "minimum": 0 },
          "reset_at": { "type": "string", "format": "date-time" }
        }
      },
      "ErrorResponse": { "type": "object", "required": ["error"], "properties": { "error": { "type": "string" } } }
    }
  }
}
