# See crates/api/src/lib.rs (Config::from_env) for the source of truth.

# Port the API listens on. Render sets this automatically.
PORT=3000

# Max size of an inbound request body, in bytes.
LECTITO_MAX_BODY_BYTES=524288

# Max size of a fetched upstream document, in bytes.
LECTITO_MAX_FETCH_BYTES=2097152

# How many HTTP redirects to follow when fetching an upstream URL.
LECTITO_REDIRECT_LIMIT=5

# Per-request timeout, including the upstream fetch, in seconds.
LECTITO_REQUEST_TIMEOUT_SECS=20

# Comma-separated list of allowed CORS origins. Empty (unset) allows any origin.
#
# In production, set this to the web app origin, e.g. https://lectito.stormlightlabs.org
# LECTITO_ALLOWED_ORIGINS=https://lectito.stormlightlabs.org

# Allow fetching private/loopback/link-local network targets.
# DISABLED in production to prevent SSRF. Set to true only for local testing.
LECTITO_ALLOW_PRIVATE_NETWORK=false
